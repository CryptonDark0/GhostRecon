# GhostRecon Tactical Suite - Safe Gitignore

# Dependencies
node_modules/
/node_modules
.yarn/

# Expo & Metro
.expo/
dist/
web-build/
expo-env.d.ts
.metro-health-check*

# Firebase Sensitive Config (Android/iOS)
# DO NOT UPLOAD THESE TO GITHUB
google-services.json
GoogleService-Info.plist
*token.json*
*credentials.json*

# Environment & Private Keys
.env
.env.*
*.local
*.key
*.pem
*.jks
*.p8
*.p12
*.mobileprovision

# Native Build Folders
android/build/
android/.gradle/
ios/build/
ios/Pods/

# IDE & Editors
.idea/
.vscode/
*.swp
*.swo

# Debug & Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
firebase-debug.log*
.cache/

# System Files
.DS_Store
Thumbs.db
